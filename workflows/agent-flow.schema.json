{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ypmcn.local/schemas/agent-flow.schema.json",
  "title": "YPmcn Cross-session Agent Flow Contracts",
  "oneOf": [
    { "$ref": "#/$defs/taskDefinition" },
    { "$ref": "#/$defs/runtimeState" },
    { "$ref": "#/$defs/verificationResult" }
  ],
  "$defs": {
    "shaOrNull": {
      "anyOf": [
        { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        { "type": "null" }
      ]
    },
    "runStatus": {
      "enum": [
        "READY",
        "DISPATCHED",
        "EXECUTING",
        "EXECUTOR_DONE",
        "VERIFYING",
        "PASS",
        "FAIL",
        "BLOCKED",
        "REWORK_READY",
        "MERGE_READY",
        "MERGED",
        "ARCHIVED"
      ]
    },
    "taskDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "change_id",
        "change_type",
        "change_status",
        "run_status",
        "goal",
        "approved_spec_version",
        "change_proposal",
        "impact_analysis",
        "risk_level",
        "execution_profile",
        "profile_reason",
        "depends_on",
        "conflicts_with",
        "allowed_paths",
        "forbidden_paths",
        "acceptance",
        "verification",
        "rollback",
        "attempt",
        "branch",
        "worktree",
        "base_sha",
        "next_action"
      ],
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "change_id": { "type": "string", "minLength": 1 },
        "change_type": { "type": "string", "minLength": 1 },
        "change_status": { "const": "SPEC_APPROVED" },
        "run_status": { "$ref": "#/$defs/runStatus" },
        "goal": { "type": "string", "minLength": 1 },
        "approved_spec_version": { "type": "string", "minLength": 1 },
        "change_proposal": { "type": "string", "minLength": 1 },
        "impact_analysis": { "type": "string", "minLength": 1 },
        "risk_level": { "enum": ["low", "medium", "high", "critical"] },
        "execution_profile": {
          "enum": [
            "executor-sol-max-fast",
            "executor-terra-max-fast",
            "executor-terra-medium-fast"
          ]
        },
        "profile_reason": { "type": "string", "minLength": 1 },
        "attempt": { "type": "integer", "minimum": 1 },
        "depends_on": { "type": "array", "items": { "type": "string" } },
        "conflicts_with": { "type": "array", "items": { "type": "string" } },
        "allowed_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "forbidden_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "acceptance": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "verification": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "rollback": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "pattern": "^codex/" },
        "worktree": { "type": "string", "minLength": 1 },
        "base_sha": { "$ref": "#/$defs/shaOrNull" },
        "next_action": { "type": "string", "minLength": 1 }
      }
    },
    "runtimeState": {
      "type": "object",
      "additionalProperties": true,
      "required": ["task_id", "run_status", "attempt", "updated_at"],
      "properties": {
        "task_id": { "type": "string" },
        "run_status": { "$ref": "#/$defs/runStatus" },
        "attempt": { "type": "integer", "minimum": 1 },
        "codex_session_id": { "type": ["string", "null"] },
        "controller_pid": { "type": ["integer", "null"], "minimum": 1 },
        "codex_process_pid": { "type": ["integer", "null"], "minimum": 1 },
        "base_sha": { "$ref": "#/$defs/shaOrNull" },
        "checkpoint_sha": { "$ref": "#/$defs/shaOrNull" },
        "head_sha": { "$ref": "#/$defs/shaOrNull" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "verificationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "base_sha",
        "head_sha",
        "verifier",
        "status",
        "commands",
        "findings",
        "evidence",
        "known_risks",
        "unexpected_writes"
      ],
      "properties": {
        "task_id": { "type": "string" },
        "base_sha": { "$ref": "#/$defs/shaOrNull" },
        "head_sha": { "$ref": "#/$defs/shaOrNull" },
        "status": { "enum": ["PASS", "FAIL", "BLOCKED"] },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/commandResult" }
        },
        "findings": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "known_risks": { "type": "array", "items": { "type": "string" } },
        "unexpected_writes": { "type": "array", "items": { "type": "string" } },
        "verifier": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tool", "model", "mode"],
          "properties": {
            "tool": { "const": "OpenCode" },
            "model": { "type": "string", "pattern": "^yuepu/" },
            "mode": { "const": "read-only" }
          }
        }
      }
    },
    "commandResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "result", "evidence"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "result": { "enum": ["PASS", "FAIL", "NOT_RUN"] },
        "evidence": { "type": "string" }
      }
    }
  }
}
