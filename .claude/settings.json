{
  "model": "fable",
  "effortLevel": "medium",
  "env": {
    "ANTHROPIC_DEFAULT_FABLE_MODEL": "gpt-5.6-sol[1M]",
    "ANTHROPIC_DEFAULT_FABLE_MODEL_NAME": "gpt-5.6-sol"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/agent-flow-hook.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
