{
  "schemaVersion": 1,
  "profile": "mvp-v2",
  "providerContractBasis": {
    "endpoint": "https://mcp.eshypdata.com/sse",
    "productionEndpoint": "https://mcp.eshypdata.com/sse",
    "activeProfile": "development",
    "inputAuthority": "live-tools/list",
    "schemaSelection": "current-endpoint-over-old-mvp-v2",
    "ignoredToolPrefix": "pgy",
    "advertisedOutputSchema": false
  },
  "mode": "writable",
  "vectorCapabilityBoundary": {
    "publicBusinessVectorTools": [],
    "excludedNamespace": "vector-mcp",
    "operationsTools": [
      "sync_creator_tag_vectors",
      "health_check_vector_store"
    ],
    "internalConsumers": ["search_creators", "rank_creators"],
    "search_creators": {
      "role": "hard-filter-candidate-recall-and-provenance",
      "vectorUse": "internal-shadow-capability",
      "hardConstraintsAuthoritativeSource": "mysql",
      "returnVerification": "current-mysql-record",
      "degradation": "sql-only-with-provenance-and-degraded-reason",
      "resultFieldAuthority": {
        "creatorIdentity": "platform creator table joined by platform + kwUid",
        "creatorPrices": "xhs_creator_accounts or dy_creator_accounts: kolOfficialPriceL1/L2/L3 and downloadPriceL1/L2/L3",
        "creatorSupplierRebate": "core_supplier.default_rebate_rate joined through creator_supply_offers.supplier_id",
        "requirementRebateThreshold": "customer_demands.rebate contains original customer wording; any parsed filter is input only and never actual supplier rebate",
        "legacyPriceCents": "not authoritative when creator price tiers exist"
      }
    },
    "rank_creators": {
      "role": "accepted-candidates-only-missing-aware-explainable-ranking",
      "vectorUse": "soft-feature-only",
      "acceptedStatuses": ["accepted"],
      "provenanceRequired": true
    }
  },
  "serverIdentity": {
    "canonicalNamespace": "ypmcn",
    "hostQualifiedToolName": {
      "format": "mcp__ypmcn__<contract-tool>",
      "pattern": "^mcp__ypmcn__(?:validate_requirement|search_creators|rank_mcns|select_inquiry_form_fields|create_with_distributions|sync_mcn_inquiry_status|ingest_mcn_submissions|manual_source_creators|rank_creators|create_submission_batch|record_client_feedback|get_recommendation_run_detail|get_creator_detail|audit_manual_adjustment|get_workflow_state)$",
      "businessToolIdentity": "exact-qualified-name-and-contract-tool",
      "bareHookEvent": "not-a-business-tool"
    },
    "providerToolsList": {
      "toolNameFormat": "bare-contract-tool",
      "namespace": "not-applicable",
      "businessToolIdentity": "catalog-membership-only"
    },
    "excludedNamespaces": [
      "vector-mcp"
    ]
  },
  "requiredTools": [
    "validate_requirement",
    "search_creators",
    "rank_mcns",
