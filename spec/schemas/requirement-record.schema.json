{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ypmcn.local/schemas/requirement-record.schema.json",
  "title": "YPmcn customer_demands Record",
  "type": "object",
  "required": [
    "id",
    "status",
    "platform",
    "rebate",
    "quantityTotal",
    "submissionDeadlineAt",
    "rawMessagesJson"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 32, "maxLength": 32},
    "demandId": {"type": ["string", "null"], "maxLength": 255},
    "demandVersion": {"type": ["integer", "null"], "minimum": 1},
    "status": {"enum": ["draft", "ready", "closed", "archived"]},
    "brandName": {"type": ["string", "null"], "maxLength": 255},
    "projectName": {"type": ["string", "null"], "maxLength": 255},
    "product": {"type": ["string", "null"], "maxLength": 255},
    "platform": {"enum": ["xiaohongshu", "douyin"]},
    "rebate": {"type": "string", "maxLength": 255},
    "quantityTotal": {"type": "integer", "minimum": 1},
    "projectStartStart": {"$ref": "#/$defs/nullableDateTime"},
    "projectStartEnd": {"$ref": "#/$defs/nullableDateTime"},
    "submissionDeadlineAt": {"$ref": "#/$defs/dateTime"},
    "rawMessagesJson": {"$ref": "#/$defs/briefAudit"},
    "createdAt": {"$ref": "#/$defs/nullableDateTime"},
    "updatedAt": {"$ref": "#/$defs/nullableDateTime"},
    "contentTag": {"type": ["string", "null"]},
    "description": {"type": ["string", "null"]},
    "contentFeatureLabel": {"$ref": "#/$defs/nullableLabelJson"},
    "contentThemeLabel": {"$ref": "#/$defs/nullableLabelJson"},
    "kolPersonaLabel": {"$ref": "#/$defs/nullableLabelJson"},
    "talentTypeLabel": {"$ref": "#/$defs/nullableLabelJson"},
    "pgyBloggerTypeLabel": {"$ref": "#/$defs/nullableLabelJson"},
    "xtTalentTypeLabel": {"$ref": "#/$defs/nullableLabelJson"},
    "kwGender": {"type": ["string", "null"], "maxLength": 16},
    "kwIpDependency": {"type": ["string", "null"], "maxLength": 128},
    "kwUserUrl": {"type": ["string", "null"], "maxLength": 1024},
    "organization": {"type": ["string", "null"], "maxLength": 255},
    "hasOrganization": {"type": ["boolean", "null"]},
    "hasOrder30day": {"type": ["boolean", "null"]},
    "hasSocial30day": {"type": ["boolean", "null"]},
    "interactionRate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "clickMedium": {"type": ["integer", "null"], "minimum": 0},
    "viewMedium": {"type": ["integer", "null"], "minimum": 0},
    "photoView": {"type": ["integer", "null"], "minimum": 0},
    "videoInteract": {"type": ["integer", "null"], "minimum": 0},
    "photoInteract": {"$ref": "#/$defs/nullableRange"},
    "followercount": {"$ref": "#/$defs/nullableRange"},
    "userlikecount": {"$ref": "#/$defs/nullableRange"},
    "likeIncrement": {"$ref": "#/$defs/nullableRange"},
    "avgview": {"$ref": "#/$defs/nullableRange"},
    "avglike": {"$ref": "#/$defs/nullableRange"},
    "avgcomment": {"$ref": "#/$defs/nullableRange"},
    "avgcollect": {"$ref": "#/$defs/nullableRange"},
    "avginteract": {"$ref": "#/$defs/nullableRange"},
    "femaleRate": {"$ref": "#/$defs/nullableRange"},
    "age1Rate": {"$ref": "#/$defs/nullableRate"},
    "age2Rate": {"$ref": "#/$defs/nullableRate"},
    "age3Rate": {"$ref": "#/$defs/nullableRate"},
    "age4Rate": {"$ref": "#/$defs/nullableRate"},
    "age5Rate": {"$ref": "#/$defs/nullableRate"},
    "age6Rate": {"$ref": "#/$defs/nullableRate"},
    "cpeL1": {"$ref": "#/$defs/nullableRange"},
    "cpeL2": {"$ref": "#/$defs/nullableRange"},
    "cpeL3": {"$ref": "#/$defs/nullableRange"},
    "cpmL1": {"$ref": "#/$defs/nullableRange"},
    "cpmL2": {"$ref": "#/$defs/nullableRange"},
    "cpmL3": {"$ref": "#/$defs/nullableRange"},
    "kolOfficialPriceL1": {"$ref": "#/$defs/nullableRange"},
    "kolOfficialPriceL2": {"$ref": "#/$defs/nullableRange"},
    "kolOfficialPriceL3": {"$ref": "#/$defs/nullableRange"}
  },
  "additionalProperties": false,
  "x-source": {
    "database": "ypmcn",
    "table": "customer_demands",
    "verifiedAt": "2026-07-18",
    "columnCount": 61
  },
  "x-constraints": [
    "projectStartStart <= projectStartEnd when both are present",
    "every [min,max] string has finite non-negative bounds and min <= max",
    "photoInteract and femaleRate bounds are <= 1",
    "age1Rate..age6Rate are direct numeric rates from 0 through 1 using platform-specific age bands",
    "hasOrganization, hasOrder30day and hasSocial30day are booleans",
    "at least one kolOfficialPriceL1/L2/L3 has a positive upper bound before status=ready"
  ],
  "$defs": {
    "dateTime": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
    },
    "nullableDateTime": {
      "anyOf": [
        {"$ref": "#/$defs/dateTime"},
        {"type": "null"}
      ]
    },
    "range": {
      "type": "string",
      "pattern": "^\\[(?:0|[1-9]\\d*)(?:\\.\\d+)?,(?:0|[1-9]\\d*)(?:\\.\\d+)?\\]$"
    },
    "nullableRange": {
      "anyOf": [
        {"$ref": "#/$defs/range"},
        {"type": "null"}
      ]
    },
    "nullableRate": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "nullableLabelJson": {
      "type": ["array", "object", "null"]
    },
    "briefAudit": {
      "type": "object",
      "required": ["schemaVersion", "originalBrief", "atoms", "coverageCheck"],
      "properties": {
        "schemaVersion": {"const": "ypmcn-brief-v1"},
        "originalBrief": {"type": "string", "minLength": 1},
        "atoms": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/briefAtom"}
        },
        "coverageCheck": {
          "type": "object",
          "required": ["atomCount", "mappedCount", "preservedCount", "unresolvedCount"],
          "properties": {
            "atomCount": {"type": "integer", "minimum": 1},
            "mappedCount": {"type": "integer", "minimum": 0},
            "preservedCount": {"type": "integer", "minimum": 0},
            "unresolvedCount": {"const": 0}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "briefAtom": {
      "type": "object",
      "required": ["sourceText", "disposition", "confidence", "inferred"],
      "properties": {
        "sourceText": {"type": "string", "minLength": 1},
        "disposition": {"enum": ["mapped", "preserved"]},
        "targetField": {"type": "string", "minLength": 1},
        "preservedText": {"type": "string", "minLength": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "inferred": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  }
}
