{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ypmcn.local/schemas/workflow-state.schema.json",
  "title": "YPmcn Database-Derived Workflow Projection",
  "description": "Workflow phase projection derived from committed provider database facts; provider output remains unadvertised.",
  "type": "object",
  "required": [
    "projection_status",
    "phase",
    "updated_at"
  ],
  "properties": {
    "projection_status": {
      "const": "database-derived"
    },
    "phase": {
      "enum": [
        "requirement_draft",
        "requirement_ready",
        "candidate_pool_ready",
        "mcn_planning",
        "waiting_mcn_return",
        "candidate_pool_enriched",
        "recommendation_ready",
        "submission_batch_ready",
        "feedback_routing",
        "blocked",
        "closed"
      ]
    },
    "requirement_id": {
      "type": "string",
      "minLength": 1
    },
    "mcn_recommendation_id": {
      "type": "string",
      "minLength": 1,
      "description": "Local confirmation binding only; never a current Endpoint provider argument."
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "mcn_id": {
      "type": "string",
      "minLength": 1
    },
    "inquiry_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
