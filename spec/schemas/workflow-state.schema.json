{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ypmcn.local/schemas/workflow-state.schema.json",
  "title": "YPmcn Local Session Projection",
  "description": "Fail-closed hook projection derived only from explicit actual tool evidence; it is not provider state or an advertised provider output.",
  "type": "object",
  "required": [
    "projection_status",
    "phase",
    "updated_at"
  ],
  "properties": {
    "projection_status": {
      "const": "local-session-projection"
    },
    "phase": {
      "enum": [
        "requirement_draft",
        "requirement_ready",
        "search_completed",
        "mcn_planning",
        "field_selection_ready",
        "distribution_sync_pending",
        "waiting_return",
        "recovering",
        "recovery_sync_pending",
        "recovered",
        "recommendation_ready",
        "submission_batch_ready",
        "feedback_routing",
        "blocked"
      ]
    },
    "requirement_id": {
      "type": "string",
      "minLength": 1
    },
    "mcn_recommendation_id": {
      "type": "string",
      "minLength": 1,
      "description": "Local confirmation binding only; never a current Endpoint provider argument."
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "mcn_id": {
      "type": "string",
      "minLength": 1
    },
    "inquiry_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
