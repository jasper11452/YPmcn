{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ypmcn.local/schemas/workflow-state.schema.json",
  "title": "YPmcn Local Workflow Orchestration State",
  "description": "Session-scoped local JSON state recorded from actual Tool results; Provider output remains business evidence but does not drive orchestration phase.",
  "type": "object",
  "required": [
    "phase",
    "next_action",
    "waiting_for",
    "transition_seq",
    "updated_at_ms"
  ],
  "properties": {
    "phase": {
      "enum": [
        "requirement_draft",
        "requirement_ready",
        "candidate_pool_ready",
        "mcn_planning",
        "inquiry_fields_ready",
        "waiting_mcn_return",
        "candidate_pool_enriched",
        "recommendation_ready",
        "submission_batch_ready",
        "feedback_routing",
        "blocked",
        "closed"
      ]
    },
    "next_action": {"type": ["string", "null"]},
    "waiting_for": {"type": ["string", "null"]},
    "transition_seq": {"type": "integer", "minimum": 0},
    "updated_at_ms": {"type": ["integer", "null"]},
    "requirement_id": {"type": "string", "pattern": "^[0-9a-fA-F]{32}$"},
    "post_validation_intent": {"enum": ["search", "manual"]},
    "post_validation_actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {"enum": ["search_creators", "manual_source_creators"]}
    },
    "preflight_error": {
      "enum": [
        "brief_mismatch",
        "missing_session_context",
        "primary_key_format",
        "requirement_id_mismatch",
        "requirement_receipt_missing"
      ]
    },
    "pre_race_supply_contract": {"enum": ["supply-assessment-v2", "legacy-v1"]},
    "pre_race_recommended_action": {"type": "string", "minLength": 1},
    "platform": {"enum": ["xiaohongshu", "douyin"]},
    "quantity_total": {"type": "integer", "minimum": 1},
    "manual_sourcing_size": {"type": "string", "pattern": "^[1-9][0-9]*$"},
    "manual_sourcing_inquiry_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "submission_batch_number": {"type": "string", "pattern": "^[1-9][0-9]*$"},
    "run_id": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
