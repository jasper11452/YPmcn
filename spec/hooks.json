{
  "schemaVersion": 3,
  "profile": "mvp-v2",
  "implementation": "YPmcn/src/index.ts",
  "handlerImplementation": "YPmcn/src/runtime-hooks.ts",
  "executionSurface": "YP Action/OpenClaw Node plugin",
  "events": {
    "before_agent_reply": {
      "responsibility": "short_circuit_unresolved_standard_briefs_with_deterministic_structured_reply",
      "mayBlock": false,
      "script": "YPmcn/src/index.ts"
    },
    "before_prompt_build": {
      "responsibility": "inject_strict_brief_and_continuous_workflow_context",
      "mayBlock": false,
      "script": "YPmcn/src/index.ts"
    },
    "before_tool_call": {
      "responsibility": "deterministic_contract_permission_and_confirmation_guards",
      "mayBlock": true,
      "script": "YPmcn/src/runtime-hooks.ts"
    },
    "after_tool_call": {
      "responsibility": "consume_or_invalidate_local_confirmation_receipts_without_advancing_business_phase",
      "mayBlock": false,
      "script": "YPmcn/src/runtime-hooks.ts"
    },
    "session_end": {
      "responsibility": "opportunistic_expired_confirmation_cleanup",
      "mayBlock": false,
      "script": "YPmcn/src/runtime-hooks.ts"
    }
  },
  "stateStore": {
    "path": "YPmcn/state/sessions/<sha256(sessionKey)>/confirmation_guard.json (legacy fallback: YPmcn/state/confirmation_guard.json when session context is unavailable)",
    "ttl": {
      "oneTimeConfirmations": "10m",
      "readyRequirementBinding": "30m",
      "workflowStateSupplyPlanAndTrustedIds": "60m",
      "blockedWriteTurn": "2m"
    },
    "format": "confirmation_guard_schema_v2",
    "storesBusinessPayload": false,
    "authoritative": false
  },
  "boundaries": {
    "owns": [
      "input_completeness",
      "format_validation",
      "preconditions",
      "permission_guards",
      "risk_blocking",
      "one_time_confirmation_fingerprints"
    ],
    "doesNotOwn": [
      "database_schema",
      "mcp_tool_schema",
      "workflow_state_authority",
      "allowed_actions",
      "recovery_ownership_or_authorization",
      "business_ranking_algorithm",
      "provider_evidence_rewrite",
      "server_side_idempotency"
    ],
    "localConfirmationProjection": {
      "authoritative": false,
      "mayGrantServerAction": false,
      "mayDenyForAdditionalSafety": true,
      "advancesBusinessPhase": false,
      "authoritativeContract": "workflow.json#stateAuthority"
    }
  },
  "legacyArtifacts": {
    "paths": [
      "YPmcn/hooks/pre_tool_guard.py",
      "YPmcn/hooks/post_tool_update.py",
      "YPmcn/hooks/session_cleanup.py",
      "tests/test_hooks.py"
    ],
    "status": "historical-regression-only",
    "includedInCurrentVerification": false,
    "includedInReleasePackage": false
  }
}
