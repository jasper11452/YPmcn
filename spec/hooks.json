{
  "schemaVersion": 2,
  "profile": "mvp-v2",
  "implementation": "YPmcn/hooks/pre_tool_guard.py",
  "events": {
    "PreToolUse": {
      "responsibility": "deterministic_precondition_and_permission_guards_with_soft_reference_context",
      "mayBlock": true,
      "script": "YPmcn/hooks/pre_tool_guard.py"
    },
    "PostToolUse": {
      "responsibility": "validated_runtime_state_projection",
      "mayBlock": false,
      "script": "YPmcn/hooks/post_tool_update.py"
    },
    "Stop": {
      "responsibility": "delete_expired_session_projections",
      "mayBlock": false,
      "script": "YPmcn/hooks/session_cleanup.py"
    }
  },
  "stateStore": {
    "path": "YPmcn/state/session_guard.json",
    "ttl": "24h",
    "format": "session_guard_schema_v1"
  },
  "boundaries": {
    "owns": [
      "input_completeness",
      "format_validation",
      "preconditions",
      "permission_guards",
      "risk_blocking"
    ],
    "doesNotOwn": [
      "database_schema",
      "mcp_tool_schema",
      "workflow_state_authority",
      "allowed_actions",
      "recovery_ownership_or_authorization",
      "business_ranking_algorithm",
      "provider_evidence_rewrite"
    ],
    "sessionProjection": {
      "authoritative": false,
      "mayGrantServerAction": false,
      "mayDenyForAdditionalSafety": true,
      "authoritativeContract": "workflow.json#stateAuthority"
    }
  }
}
