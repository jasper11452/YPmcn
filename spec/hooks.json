{
  "schemaVersion": 6,
  "profile": "mvp-v2",
  "implementation": "YPmcn/src/index.ts",
  "handlerImplementation": "YPmcn/src/runtime-hooks.ts",
  "executionSurface": "YP Action/OpenClaw Node plugin",
  "events": {
    "before_prompt_build": {
      "responsibility": "extract_real_client_brief_and_observe_audited_manual_creator_markdown_display_then_inject_human_in_the_loop_multi_platform_guidance_and_local_json_orchestration_state",
      "mayBlock": false,
      "script": "YPmcn/src/index.ts"
    },
    "before_tool_call": {
      "responsibility": "exact_brief_and_requirement_primary_key_preflight_plus_one_time_same_session_manual_binding_plus_non_blocking_repeated_rank_notice_plus_native_external_send_approval_and_shell_bypass_guard",
      "mayBlock": true,
      "script": "YPmcn/src/runtime-hooks.ts"
    },
    "after_tool_call": {
      "responsibility": "record_actual_tool_results_and_local_workflow_transitions_without_reopening_the_field_selector",
      "mayBlock": false,
      "script": "YPmcn/src/runtime-hooks.ts"
    },
    "session_end": {
      "responsibility": "opportunistic_expired_confirmation_cleanup",
      "mayBlock": false,
      "script": "YPmcn/src/runtime-hooks.ts"
    }
  },
  "stateStore": {
    "path": "YPmcn/state/sessions/<sha256(sessionKey)>/confirmation_guard.json; the legacy global file may hold non-authorizing diagnostics only",
    "ttl": {
      "oneTimeConfirmations": "10m",
      "unknownExternalSend": "10m; every retry requires a fresh explicit confirmation"
    },
    "format": "confirmation_guard_schema_v19",
    "storesBusinessPayload": false,
    "storesWorkflowIdentifiers": true,
    "authoritativeForOrchestration": true,
    "authoritativeForProviderSuccess": false
  },
  "boundaries": {
    "owns": [
      "external_send_confirmation",
      "external_send_request_fingerprint_binding",
      "provider_send_shell_bypass_blocking",
      "one_time_confirmation_fingerprints",
      "manual_sourcing_fresh_requirement_receipt_binding",
      "search_and_manual_requirement_primary_key_shape_validation",
      "exact_original_brief_hash_preflight",
      "one_time_manual_requirement_consumption",
      "non_blocking_repeated_rank_requirement_notice",
      "callback_returned_field_selection_reuse_without_browser_reopen",
      "local_workflow_phase_and_next_action_recording",
      "manual_creator_data_receipt_and_list_display_audit",
      "sync_after_wecom_order_audit"
    ],
    "doesNotOwn": [
      "general_tool_permissions",
      "requirement_input_validation",
      "general_tool_parameter_validation_beyond_requirement_primary_keys_and_original_brief",
      "workflow_order_enforcement",
      "rank_creators_duplicate_call_blocking",
      "field_selector_browser_opening_or_reopening",
      "identifier_provenance_enforcement_beyond_current_search_and_manual_requirement_receipts",
      "historical_requirement_or_search_lookup",
      "provider_requirement_id_uniqueness",
      "database_schema",
      "mcp_tool_schema",
      "provider_business_fact_authority",
      "provider_action_authorization",
      "recovery_ownership_or_authorization",
      "business_ranking_algorithm",
      "provider_evidence_rewrite",
      "server_side_idempotency"
    ],
    "localOrchestrationProjection": {
      "authoritative": true,
      "mayGrantServerAction": false,
      "mayDenyOrdinaryToolOrder": false,
      "advancesOnlyOnActualSuccess": true,
      "authoritativeContract": "workflow.json#stateAuthority"
    },
    "manualSourcingGuard": {
      "phaseIndependent": true,
      "requiredPredecessor": "validate_requirement",
      "requiredEvidence": "fresh 32-character data.id primary key from the immediately preceding successful response, persisted and consumed by the plugin itself",
      "oneTime": true,
      "checksHistoricalSearch": false,
      "checksOtherWorkflowCompletion": false,
      "storesRawRequirementId": false,
      "missingSessionContext": "use the plugin-owned global one-time handoff receipt; exact ID matching and single consumption still apply"
    },
    "searchRequirementGuard": {
      "primaryKeySource": "validate_requirement.data.id",
      "rejects": ["data.demand_id", "demand_version", "non-32-hex-identifiers"],
      "scopedBehavior": "bind to the latest same-session validation receipt",
      "unscopedBehavior": "shape-only degraded validation; no global provenance authorization"
    },
    "briefIntegrityGuard": {
      "binding": "sha256 of each exact real client Brief recovered from the current prompt and recent user messages after host-envelope stripping",
      "storesRawBrief": false,
      "clarificationBehavior": "AskUserQuestion payloads and later Tool-argument JSON do not replace an earlier real Brief; embedded originalBrief is fallback-only when no direct Brief is available",
      "multiPlatform": "every independently validated payload retains the same full originalBrief",
      "authorizationUse": false
    },
    "rankCreatorsRepeatNotice": {
      "comparison": "current rank_creators.requirement_id equals the immediately previous rank_creators call in the same state scope",
      "message": "已根据需求进行排序，请注意",
      "mayBlock": false,
      "storesRawRequirementId": false
    },
    "fieldSelectionCallback": {
      "resultSource": "actual fields returned by select_inquiry_form_fields after its webpage callback",
      "reopenSelectorAfterToolResult": false,
      "storesRawFields": false
    }
  },
  "legacyArtifacts": {
    "paths": [
      "YPmcn/hooks/pre_tool_guard.py",
      "YPmcn/hooks/post_tool_update.py",
      "YPmcn/hooks/session_cleanup.py",
      "tests/test_hooks.py"
    ],
    "status": "historical-regression-only",
    "includedInCurrentVerification": false,
    "includedInReleasePackage": false
  }
}
