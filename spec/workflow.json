{
  "schemaVersion": 1,
  "profile": "mvp-v2",
  "projectionStatus": "local-session-projection",
  "vectorDegradationPolicy": {
    "mode": "explicit-sql-only",
    "preserveBusinessWorkflow": true,
    "requiredResultFields": ["retrieval_mode", "degraded_reason", "provenance"],
    "retrievalMode": "sql-only",
    "allowedReasons": ["vector_configuration_invalid", "embedding_unavailable", "reranker_unavailable", "vector_store_unavailable", "vector_index_stale"],
    "staleHitPolicy": "exclude-and-revalidate-from-mysql",
    "prohibitedSubstitutes": ["fake-qdrant", "local-json-as-production-result"]
  },
  "phases": [
    "requirement_draft",
    "requirement_ready",
    "search_completed",
    "mcn_planning",
    "field_selection_ready",
    "distribution_sync_pending",
    "waiting_return",
    "recovering",
    "recovery_sync_pending",
    "recovered",
    "recommendation_ready",
    "submission_batch_ready",
    "feedback_routing",
    "blocked"
  ],
  "allowedActions": [
    "validate_requirement",
    "search_creators",
    "rank_mcns",
    "select_inquiry_form_fields",
    "create_with_distributions",
    "sync_mcn_inquiry_status",
    "ingest_mcn_submissions",
    "rank_creators",
    "create_submission_batch",
    "record_client_feedback"
  ],
  "stateAuthority": {
    "source": "hook-session-projection",
    "schema": "schemas/workflow-state.schema.json",
    "providerFacts": false,
    "providerOutputSchemaAdvertised": false,
    "phaseAdvance": "explicit-actual-returned-evidence-only",
    "missingEvidenceBehavior": "no-phase-advance",
    "unknownWriteResult": "WRITE_RESULT_UNKNOWN",
    "mayGrantProviderAuthority": false,
    "mayDenyForSafety": true,
    "sessionTtl": "24h",
    "rawPayloadStored": false
  },
  "policies": {
    "outwardSendConfirmation": "sessionKey + toolCallId + operator.write + supply/mcn/message confirmations",
    "fieldSelectionBinding": "description field names map one-to-one in order to final columns",
    "unsupportedProviderArguments": [
      "candidate_pool_id",
      "mcn_recommendation_id",
      "preview_only",
      "remindAt",
      "trigger"
    ],
    "recoverySequence": [
      "sync_mcn_inquiry_status",
      "ingest_mcn_submissions",
      "sync_mcn_inquiry_status"
    ],
    "scheduledRecoveryRequires": "ctx.trigger=cron and cron_job_id",
    "providerStatuses": "observed-only; never interpreted as advertised facts"
  },
  "transitions": [
    {
      "id": "requirement-validated",
      "from": "requirement_draft",
      "trigger": { "type": "tool", "name": "validate_requirement" },
      "guards": ["payload matches live input schema"],
      "evidence": ["actual success === true", "actual data.requirement_id or data.id"],
      "nextPhase": "requirement_ready"
    },
    {
      "id": "search-completed",
      "from": "requirement_ready",
      "trigger": { "type": "tool", "name": "search_creators" },
      "guards": ["params.id matches current requirement evidence"],
      "evidence": ["actual success === true"],
      "nextPhase": "search_completed"
    },
    {
      "id": "mcn-plan-observed",
      "from": "search_completed",
      "trigger": { "type": "tool", "name": "rank_mcns" },
      "guards": ["params.id matches current requirement evidence"],
      "evidence": ["actual success === true", "actual mcn_recommendation_id or id for local confirmation binding"],
      "nextPhase": "mcn_planning"
    },
    {
      "id": "field-description-observed",
      "from": "mcn_planning",
      "trigger": { "type": "tool", "name": "select_inquiry_form_fields" },
      "guards": ["description parses as unique 数据库字段名：字段备注 lines"],
      "evidence": ["actual success === true", "actual description"],
      "nextPhase": "field_selection_ready"
    },
    {
      "id": "distribution-sent",
      "from": "field_selection_ready",
      "trigger": { "type": "tool", "name": "create_with_distributions" },
      "guards": [
        "sessionKey and toolCallId present",
        "operator.write confirmation binds local mcn recommendation evidence",
        "columns bind one-to-one to selected description",
        "all live required inputs present"
      ],
      "evidence": ["actual success === true", "actual project_id", "actual mcn_id"],
      "nextPhase": "distribution_sync_pending"
    },
    {
      "id": "initial-sync-observed",
      "from": "distribution_sync_pending",
      "trigger": { "type": "tool", "name": "sync_mcn_inquiry_status" },
      "guards": ["requirement_id, project_id, and mcn_id match current evidence"],
      "evidence": ["actual success === true"],
      "nextPhase": "waiting_return"
    },
    {
      "id": "recovery-sync-observed",
      "from": "waiting_return",
      "trigger": { "type": "tool", "name": "sync_mcn_inquiry_status" },
      "guards": ["current manual intent or scheduled cron evidence"],
      "evidence": ["actual success === true", "actual inquiry_id required before ingest"],
      "nextPhase": "recovering"
    },
    {
      "id": "ingest-observed",
      "from": "recovering",
      "trigger": { "type": "tool", "name": "ingest_mcn_submissions" },
      "guards": ["inquiry_id and recovery origin match current sync evidence"],
      "evidence": ["actual success === true"],
      "nextPhase": "recovery_sync_pending"
    },
    {
      "id": "final-sync-observed",
      "from": "recovery_sync_pending",
      "trigger": { "type": "tool", "name": "sync_mcn_inquiry_status" },
      "guards": ["sync identifiers and recovery origin match current ingest evidence"],
      "evidence": ["actual success === true"],
      "nextPhase": "recovered"
    },
    {
      "id": "recommendation-run-observed",
      "from": "recovered",
      "trigger": { "type": "tool", "name": "rank_creators" },
      "guards": ["requirement_id matches current evidence"],
      "evidence": ["actual success === true", "actual run_id promised by tool description"],
      "nextPhase": "recommendation_ready"
    },
    {
      "id": "submission-batch-observed",
      "from": "recommendation_ready",
      "trigger": { "type": "tool", "name": "create_submission_batch" },
      "guards": ["run_id matches current evidence"],
      "evidence": ["actual success === true"],
      "nextPhase": "submission_batch_ready"
    },
    {
      "id": "feedback-observed",
      "from": "submission_batch_ready",
      "trigger": { "type": "tool", "name": "record_client_feedback" },
      "guards": ["run_id matches current evidence"],
      "evidence": ["actual success === true"],
      "nextPhase": "feedback_routing"
    }
  ]
}
