{
  "schemaVersion": 1,
  "profile": "mvp-v2",
  "projectionStatus": "database-derived",
  "vectorDegradationPolicy": {
    "mode": "explicit-sql-only",
    "preserveBusinessWorkflow": true,
    "requiredResultFields": ["retrieval_mode", "degraded_reason", "provenance"],
    "retrievalMode": "sql-only",
    "allowedReasons": ["vector_configuration_invalid", "embedding_unavailable", "reranker_unavailable", "vector_store_unavailable", "vector_index_stale"],
    "staleHitPolicy": "exclude-and-revalidate-from-mysql",
    "prohibitedSubstitutes": ["fake-qdrant", "local-json-as-production-result"]
  },
  "phases": [
    "requirement_draft",
    "requirement_ready",
    "candidate_pool_ready",
    "mcn_planning",
    "waiting_mcn_return",
    "candidate_pool_enriched",
    "recommendation_ready",
    "submission_batch_ready",
    "feedback_routing",
    "blocked",
    "closed"
  ],
  "allowedActions": [
    "validate_requirement",
    "search_creators",
    "rank_mcns",
    "select_inquiry_form_fields",
    "create_with_distributions",
    "sync_mcn_inquiry_status",
    "ingest_mcn_submissions",
    "manual_source_creators",
    "rank_creators",
    "audit_manual_adjustment",
    "create_submission_batch",
    "record_client_feedback",
    "get_workflow_state"
  ],
  "stateAuthority": {
    "source": "database-derived-provider-state",
    "schema": "schemas/workflow-state.schema.json",
    "providerFacts": true,
    "providerOutputSchemaAdvertised": false,
    "phaseAdvance": "derive-after-each-write-from-committed-facts",
    "missingEvidenceBehavior": "no-phase-advance",
    "unknownWriteResult": "WRITE_RESULT_UNKNOWN",
    "mayGrantProviderAuthority": true,
    "mayDenyForSafety": true,
    "sessionLifecycleRequired": false,
    "rawPayloadStored": false,
    "ledger": "mcp_tool_call_ledger"
  },
  "policies": {
    "outwardSendConfirmation": "ten-minute one-time request fingerprint confirmed through AskUserQuestion",
    "fieldSelectionBinding": "selected columns remain preparation evidence until a real distribution is committed",
    "unsupportedProviderArguments": ["candidate_pool_id", "mcn_recommendation_id", "preview_only", "remindAt", "trigger"],
    "stateRefresh": "on resume, compaction, unknown write, conflict, missing state, and before outward send",
    "unknownWriteRecovery": "get_workflow_state by demand identity or ledger trace_id; never blind retry",
    "postSearchSupplyPlanConfirmation": "AskUserQuestion confirms fielded supply-demand ratio and MCN/manual allocation before rank_mcns",
    "manualSourcingPlacement": "optional pre-send enrichment only; never proves distribution or recovery",
    "rankCreatorsPrerequisite": "committed WeCom distribution plus completed recovery"
  },
  "transitions": [
    {
      "id": "requirement-ready",
      "from": "requirement_draft",
      "trigger": {"type": "tool", "name": "validate_requirement"},
      "guards": ["payload matches live schema"],
      "evidence": ["committed ready customer_demands row"],
      "nextPhase": "requirement_ready"
    },
    {
      "id": "candidate-pool-ready",
      "from": "requirement_ready",
      "trigger": {"type": "tool", "name": "search_creators"},
      "guards": ["requirement identity resolves uniquely"],
      "evidence": ["committed creator_candidate_pool rows"],
      "nextPhase": "candidate_pool_ready"
    },
    {
      "id": "mcn-plan-ready",
      "from": "candidate_pool_ready",
      "trigger": {"type": "tool", "name": "rank_mcns"},
      "guards": ["candidate pool belongs to the same requirement", "one-time Ask supply-plan confirmation binds demand_count, database_candidate_count, supply_demand_ratio, recommended_mcn_count, recommended_manual_count, and recommended_mcn_manual_ratio"],
      "evidence": ["committed mcn_recommendation_items rows"],
      "nextPhase": "mcn_planning"
    },
    {
      "id": "distribution-waiting",
      "from": "mcn_planning",
      "trigger": {"type": "tool", "name": "create_with_distributions"},
      "guards": ["one-time Ask confirmation matches the unchanged request fingerprint", "supplier and prefill rows resolve one requirement"],
      "evidence": ["real project and distribution mirrored to mcn_inquiries"],
      "nextPhase": "waiting_mcn_return"
    },
    {
      "id": "manual-supply-before-send-from-candidate-pool",
      "from": "candidate_pool_ready",
      "trigger": {"type": "tool", "name": "manual_source_creators"},
      "guards": ["supply plan is confirmed", "manual results are real and verifiable", "no distribution has been sent"],
      "evidence": ["committed eligible manual candidates"],
      "nextPhase": "candidate_pool_ready"
    },
    {
      "id": "manual-supply-before-send-from-mcn-planning",
      "from": "mcn_planning",
      "trigger": {"type": "tool", "name": "manual_source_creators"},
      "guards": ["manual results are real and verifiable", "no distribution has been sent"],
      "evidence": ["committed eligible manual candidates"],
      "nextPhase": "mcn_planning"
    },
    {
      "id": "submission-ingested",
      "from": "waiting_mcn_return",
      "trigger": {"type": "tool", "name": "ingest_mcn_submissions"},
      "guards": ["inquiry identity and ownership resolve uniquely"],
      "evidence": ["committed valid mcn_submission_items and updated inquiry"],
      "nextPhase": "candidate_pool_enriched"
    },
    {
      "id": "recovery-completed",
      "from": "waiting_mcn_return",
      "trigger": {"type": "tool", "name": "sync_mcn_inquiry_status"},
      "guards": ["committed WeCom distribution exists", "all active platform inquiries are recovered or closed"],
      "evidence": ["authoritative completed recovery lifecycle"],
      "nextPhase": "candidate_pool_enriched"
    },
    {
      "id": "recommendation-ready",
      "from": "candidate_pool_enriched",
      "trigger": {"type": "tool", "name": "rank_creators"},
      "guards": ["committed WeCom distribution exists", "all active platform recovery facts are complete"],
      "evidence": ["successful recommendation_run and recommendation items"],
      "nextPhase": "recommendation_ready"
    },
    {
      "id": "submission-ready",
      "from": "recommendation_ready",
      "trigger": {"type": "tool", "name": "create_submission_batch"},
      "guards": ["run identity matches authoritative state"],
      "evidence": ["committed submission batch and creator submissions"],
      "nextPhase": "submission_batch_ready"
    },
    {
      "id": "feedback-recorded",
      "from": "submission_batch_ready",
      "trigger": {"type": "tool", "name": "record_client_feedback"},
      "guards": ["run identity matches authoritative state"],
      "evidence": ["committed feedback facts"],
      "nextPhase": "feedback_routing"
    }
  ]
}
