      "hash": "d64579f4edff38e46ced375483962705c72deeb375c6b3f15e34d701231ac0f7"
    }
  },
  "canonicalInput": {
    "field": "rawMessagesJson",
    "transportType": "json-object",
    "storedType": "json-object",
    "schemaVersion": "ypmcn-brief-v1",
    "canonicalization": "recursive-key-sort-json-v1-preserve-array-order",
    "requiredMembers": ["originalBrief", "atoms", "coverageCheck"],
    "compatibilityAliases": [],
    "dictionaryMayContainValues": false
  },
  "valuePolicies": {
    "mappedRanges": {
      "storageType": "varchar(255)",
      "format": "[min,max] JSON-array text without spaces",
      "minimum": 0,
      "boundsRequired": 2,
      "ordering": "min <= max",
      "exactValueRepresentation": "min === max",
      "upperBoundRepresentation": "min === 0",
      "lowerOnlyBehavior": "clarification-required-unless-a-finite-upper-bound-is-confirmed",
      "rateFields": ["photoInteract", "femaleRate", "age1Rate", "age2Rate", "age3Rate", "age4Rate", "age5Rate", "age6Rate"],
      "rateMaximum": 1,
      "mappingAuthority": "field_match_mapping",
      "onViolation": "VALUE_RANGE_INVALID"
    },
    "creatorUnitPrice": {
      "fields": ["kolOfficialPriceL1", "kolOfficialPriceL2", "kolOfficialPriceL3"],
      "businessRequiredOneOf": true,
      "unit": "CNY-yuan",
      "storage": "mappedRanges",
      "tierAmbiguityBehavior": "clarification-required"
    },
    "projectTotalBudget": {
      "dedicatedField": null,
      "behavior": "preserve-verbatim-in-rawMessagesJson"
    },
    "rebate": {
      "field": "rebate",
      "type": "string",
      "businessRequired": false,
      "behaviorWhenAbsent": "Agent must not invent; Provider owns physical non-null handling"
    },
    "deadlines": {
      "format": "YYYY-MM-DD HH:mm:ss",
      "missingBehavior": "clarification-required",
      "types": [
        {
          "name": "submissionDeadlineAt",
          "owner": "client-plan-submission",
          "required": true
        },
        {
          "name": "projectStartStart",
          "owner": "project-window-start",
          "required": false
        },
        {
          "name": "projectStartEnd",
          "owner": "project-window-end",
          "required": false
        }
      ],
      "rawWordingStorage": "matching rawMessagesJson atom",
      "prohibitedLegacyField": "submissionDeadlineRaw",
      "ordering": ["projectStartStart <= projectStartEnd when both are present"],
      "onViolation": "DEADLINE_ORDER_INVALID"
    },
    "platformSplit": {
      "supportedPlatforms": [
        "xiaohongshu",
        "douyin"
      ],
      "executionEntity": "customer_demands",
      "executionUnitPlatformCardinality": 1,
      "multiPlatformBehavior": "one independently validated customer_demands record per platform",
      "crossPlatformExecutionAllowed": false,
      "onUnsplittableInput": "INVALID_INPUT"
    }
  },
  "processingPolicies": {
    "constraintGrammar": {
      "schema": "schemas/constraint-expression.schema.json",
      "rootKinds": [
        "all",
        "any",
        "not",
        "comparison",
        "range",
        "set"
      ],
      "fieldVocabulary": {
        "source": "requirement-dictionary.json#definitions",
        "membership": "exact-key-match",
        "allowedClassifications": [
          "execution-scope",
          "money-lower-bound",
          "money-upper-bound",
          "rate-lower-bound",
          "rate-upper-bound",
          "deadline"
        ]
      },
      "unknownOperatorBehavior": "fail-closed",
      "unknownFieldBehavior": "fail-closed",
      "missingValuePolicies": [
        "reject",
        "need_review",
        "ignore-soft-only"
      ],
      "onViolation": "CONSTRAINT_GRAMMAR_INVALID"
    },
    "joinGate": {
      "evaluationPoints": [
        "before-candidate-eligibility",
        "before-ranking",
        "before-send",
        "before-offer-promotion"
      ],
      "joins": [
        {
          "id": "requirement-dictionary",
          "from": "customer_demands.(dictionary_version,dictionary_hash)",
          "to": "requirement_dictionary.(dictionaryVersion,dictionaryHash)",
          "cardinality": "exactly-one",
          "scopeRule": "hash-and-version-exact"
        },
        {
          "id": "selection-snapshot",
          "from": "selection_results.requirement_snapshot_id",
          "to": "requirement_snapshots.snapshot_id",
          "cardinality": "exactly-one",
          "scopeRule": "scope-and-requirement-exact"
        },
        {
          "id": "offer-supplier-binding",
          "from": "creator_supply_offers.supplier_binding_id",
          "to": "supplier_bindings.supplier_binding_id",
          "cardinality": "exactly-one-active-at-as-of",
          "scopeRule": "scope-and-validity-window-match"
        },
        {
          "id": "send-selection",
          "from": "send_operations.selection_result_id",
          "to": "selection_results.selection_result_id",
          "cardinality": "exactly-one",
          "scopeRule": "scope-requirement-and-state-version-exact"
        }
      ],
      "missingBehavior": "fail-closed",
      "ambiguousBehavior": "fail-closed",
      "missingOrAmbiguousError": "JOIN_GATE_FAILED",
      "scopeError": "SCOPE_MISMATCH"
    },
    "lateData": {
      "requiredLineageFields": [
        "observed_at",
        "effective_at",
        "received_at",
        "as_of_at",
        "late_data_cutoff_at",
        "is_late",
        "late_reason"
      ],
      "classification": "received_at > late_data_cutoff_at",
      "frozenArtifacts": [
        "requirement_snapshots",
        "selection_results",
        "recommendation_runs",
        "submission_batches"
      ],
      "lateRecordBehavior": "retain-lineage-and-route-to-next-snapshot-or-manual-review",
      "mutationOfFrozenArtifactAllowed": false,
      "onForbiddenMutation": "LATE_DATA_REJECTED"
    },
    "offerPromotion": {
      "sourceEntities": [
        "mcn_submission_items",
        "manual_sourced_creators"
      ],
      "targetEntity": "creator_supply_offers",
      "states": [
        "candidate",
        "validated",
        "promoted",
        "rejected",
        "superseded"
      ],
      "promotionFrom": "validated",
      "promotionTo": "promoted",
      "requirements": [
        "source-status-accepted",
        "join-gate-passed",
        "scope-match",
        "lineage-complete",
        "not-late-for-frozen-snapshot"
      ],
      "writeMode": "append-new-offer-revision-and-audit-event",
      "overwriteActiveOfferAllowed": false,
      "idempotencyKey": [
        "source_type",
        "source_record_id",
        "scope_type",
        "scope_id"
      ],
      "onConflict": "OFFER_PROMOTION_CONFLICT"
    }
  },
  "governance": {
    "defines": [
      "input-canonicalization",
      "data-validity",
      "join-admissibility",
      "snapshot-and-late-data-lifecycle",
      "offer-promotion-lifecycle"
    ],
    "doesNotDefine": [
      "creator-ranking-weight",
      "mcn-ranking-weight",
      "recall-formula",
      "scoring-threshold"
    ],
    "algorithmContract": "algorithms.json",
    "algorithmReadinessRequiredForProduction": true,
    "databaseDeploymentStatus": "development-read-only-verified-2026-07-18",
    "legacyProfileCapability": "detection-only",
    "productionReadiness": "NO-GO"
  }
}
