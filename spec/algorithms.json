{
  "schemaVersion": 1,
  "profile": "mvp-v2",
  "readinessStatus": "external-unverified",
  "definitions": {
    "mcnSupplyMultiplierDecision": {
      "status": "approved-provider-unverified",
      "decisionVersion": "2026-07-21.1",
      "creatorIdentity": ["platform", "kwUid"],
      "preRace": {
        "coverageSource": "deduplicated eligible creators in the rate-card resource library",
        "multiplier": "rate_card_creator_count / demand_count",
        "exactManualTargetAllowed": false
      },
      "postRace": {
        "coverageSource": "deduplicated union of creators covered by the actually selected inquiry suppliers",
        "multiplier": "selected_mcn_covered_creator_count / demand_count",
        "exactManualTarget": "selected multiplier < 20 ? demand_count * 20 - selected_mcn_covered_creator_count : null"
      },
      "riskBands": [
        {"risk": "high_risk", "condition": "coverage_count < demand_count * 20"},
        {"risk": "medium_risk", "condition": "demand_count * 20 <= coverage_count < demand_count * 30"},
        {"risk": "safe", "condition": "coverage_count >= demand_count * 30"}
      ],
      "comparisonRule": "compare integer coverage_count with integer demand_count multiples; rounded display multipliers never determine risk",
      "actions": {
        "high_risk": "strongly recommend expanding suppliers or pre-sourcing before the race; after the race offer the exact gap as one-click manual sourcing",
        "medium_risk": "inquiry may continue, but recommend adding suppliers or manual sourcing without inventing an exact target",
        "safe": "no manual sourcing recommendation"
      }
    }
  },
  "vectorGovernance": {
    "creatorVectorRetrieval": {
      "status": "shadow",
      "internalConsumers": ["search_creators", "rank_creators"],
      "authoritativeSource": "mysql",
      "derivedIndex": "qdrant",
      "returnVerification": "rehydrate-and-revalidate-current-mysql-record",
      "namedVectors": {
        "content": {
          "includeFields": ["creator_type", "content_types", "content_tags", "persona", "clean_description"],
          "excludeFields": ["id", "platform", "kwUid", "source_snapshot_date", "nickname", "url", "agency", "gender", "age", "region", "follower_metrics", "engagement_metrics", "cpe", "cpm", "prices", "rebate", "numeric_only_json"]
        },
        "commercial": {
          "includeFields": ["parsed_brands", "parsed_categories", "parsed_scenarios", "parsed_benefits", "parsed_ingredients", "parsed_ip"],
          "excludeFields": ["id", "platform", "kwUid", "source_snapshot_date", "nickname", "url", "agency", "gender", "age", "region", "follower_metrics", "engagement_metrics", "cpe", "cpm", "prices", "rebate", "numeric_only_json"]
        }
      },
      "hardConstraints": ["platform", "region", "follower_range", "price_range", "compliance"],
      "softFeatures": ["content_similarity", "commercial_similarity", "content_tags"],
      "softFeaturesMayOverrideHardConstraints": false,
      "rankingPolicy": {
        "missingAware": true,
        "coverageAware": true,
        "zeroIsObservedValue": true,
        "missingIsWorstValue": false,
        "cpePrimaryWeightAllowed": false,
        "explanationRequired": true
      },
      "parameters": {
        "embeddingProvider": {"status": "pending-evaluation", "value": null},
        "embeddingModel": {"status": "pending-evaluation", "value": null},
        "embeddingModelVersion": {"status": "pending-evaluation", "value": null},
        "dimensions": {"status": "pending-evaluation", "value": null},
        "normalization": {"status": "pending-evaluation", "value": null},
        "distanceMetric": {"status": "pending-evaluation", "value": null},
        "retrievalTopK": {"status": "pending-evaluation", "value": null},
        "candidateLimit": {"status": "pending-evaluation", "value": null},
        "rrfParameters": {"status": "pending-evaluation", "value": null},
        "thresholds": {"status": "pending-evaluation", "value": null},
        "rankingWeights": {"status": "pending-evaluation", "value": null},
        "rerankerProvider": {"status": "disabled", "value": null},
        "rerankerModel": {"status": "disabled", "value": null},
        "rerankerModelVersion": {"status": "disabled", "value": null}
      }
    }
  },
