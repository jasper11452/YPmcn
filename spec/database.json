  "knownGaps": [
    {
      "id": "sync-is-metadata-only",
      "severity": "critical",
      "effect": "The recovery chain cannot obtain authoritative provider status or create inquiry records."
    },
    {
      "id": "ledger-unused",
      "severity": "high",
      "effect": "Write calls do not have a shared persistent idempotency and reconciliation record."
    },
    {
      "id": "external-create-missing-client-request-id",
      "severity": "high",
      "effect": "core_project has no stable client request key, so an external create response lost after commit cannot be uniquely reconciled without one minimal column and unique index."
    },
    {
      "id": "audit-json-only",
      "severity": "medium",
      "effect": "Manual adjustment history is mutable with the recommendation row and is not an append-only audit stream."
    },
    {
      "id": "query-flags-ignored",
      "severity": "medium",
      "effect": "Some advertised include flags do not change the current response."
    }
  ],
