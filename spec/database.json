    "searchCreatorsFieldAuthority": {
      "creatorProfileSourceByPlatform": {
        "xiaohongshu": "xhs_creator_accounts",
        "douyin": "dy_creator_accounts"
      },
      "priceSource": {
        "authority": "platform creator account table",
        "fields": [
          "kolOfficialPriceL1",
          "kolOfficialPriceL2",
          "kolOfficialPriceL3",
          "downloadPriceL1",
          "downloadPriceL2",
          "downloadPriceL3",
          "predictPicturePrice",
          "predictVideoPrice"
        ],
        "rule": "Single-creator prices come from the platform creator table and are returned as price_yuan or price_cents with a price_source."
      },
      "rebateSource": {
        "authority": "core_supplier.default_rebate_rate",
        "relationship": "creator_supply_offers.supplier_id -> core_supplier.id",
        "rule": "The current creator_supply_offers table has no persisted rebate_min_rate or rebate_max_rate columns. Demand rebate fields are thresholds and must never be reported as an actual supplier rebate."
      }
    },
    "budgetSemantics": {
      "budgetMinCents": "project total budget lower bound only",
      "budgetMaxCents": "project total budget upper bound only",
      "budgetRaw": "original project total budget wording only",
      "creatorUnitPriceFields": [
        "kolOfficialPriceL1",
        "kolOfficialPriceL2",
        "kolOfficialPriceL3"
      ],
      "rule": "A creator unit-price request must not be copied into budgetMinCents, budgetMaxCents or budgetRaw. If the L1/L2/L3 tier is ambiguous, ask the user to choose the tier before calling validate_requirement."
    }
  },
