  "invariants": [
    {
      "id": "unique-supplier-mapping",
      "requirement": "one active supplier binding resolves each targeted (mcn_id, provider, scope) at an as-of time, and (provider, supplier_id) is physically unique",
      "owner": "production-database",
      "evidence": [
        "physical unique constraints uq-supplier-bindings-provider-supplier and uq-supplier-bindings-window-start exist",
        "transactional overlap guard plus as-of readiness query returns exactly one active supplier_binding_id for every targeted MCN and scope"
      ],
      "status": "external-unverified"
    },
    {
      "id": "single-send-context",
      "requirement": "one logical provider send exists per idempotency_key and every send references one persisted selection_result; an unknown outcome is reconciled before a new operation key is allowed",
      "owner": "distribution-provider-backend",
      "evidence": [
        "physical unique constraints cover send_operations.idempotency_key and (provider, provider_correlation_key)",
        "timeout scenario reuses the same send operation during reconciliation and an explicit resend creates a new operation key"
      ],
      "status": "external-unverified"
    },
    {
      "id": "stable-provider-correlation",
      "requirement": "provider send uses a stable business correlation key and an unknown outcome is queried with that key before any retry",
      "owner": "distribution-provider-backend",
      "evidence": [
        "provider contract documents the stable correlation key",
        "timeout scenario queries provider state and does not issue a second send"
      ],
      "status": "external-unverified"
    },
    {
      "id": "atomic-first-sync",
      "requirement": "first sync transactionally creates or reuses one snapshot, one inquiry batch, one inquiry per supplier, and one cron",
      "owner": "sync-mcn-inquiry-status-backend",
      "evidence": [
        "transaction and uniqueness constraints cover snapshot, inquiry batch, supplier inquiry, and cron writes",
        "concurrent first-sync test returns the same snapshot, inquiry batch, inquiries, and cron"
      ],
      "status": "external-unverified"
    },
    {
      "id": "unique-provider-references",
      "requirement": "provider_distribution_id is unique and every token and fill_link is nonempty and unique",
      "owner": "production-database-and-provider",
      "evidence": [
        "unique constraints cover provider_distribution_id, token, and fill_link",
        "provider integration test rejects empty or duplicate references"
      ],
      "status": "external-unverified"
    },
    {
      "id": "idempotent-submission-ingest",
      "requirement": "submission ingest is idempotent on (provider_distribution_id, provider_row_id)",
      "owner": "ingest-mcn-submissions-backend",
      "evidence": [
        "unique constraint on (provider_distribution_id, provider_row_id)",
        "duplicate-row integration test preserves one logical submission item"
      ],
      "status": "external-unverified"
    },
    {
      "id": "single-recovery-owner",
      "requirement": "recovery uses compare-and-swap or a row lock so concurrent manual and scheduled recovery permit one ingest owner",
      "owner": "production-database-recovery-coordinator",
      "evidence": [
        "CAS predicate or row-lock transaction is documented",
        "manual-versus-scheduled concurrency test observes one ingest owner"
      ],
      "status": "external-unverified"
    },
    {
      "id": "accepted-source-merge-priority",
      "requirement": "creator merge priority is mcn_submission > manual_source > candidate_pool and automatic rank accepts only accepted records",
      "owner": "rank-creators-backend",
      "evidence": [
        "three-source collision fixture selects the documented priority winner",
        "ranking fixture excludes need_review and every status other than accepted"
      ],
      "status": "external-unverified"
    },
    {
      "id": "submission-batch-retry",
      "requirement": "retry for a run returns its current unfinished submission batch; a new batch is created only after continue_submission",
      "owner": "create-submission-batch-backend",
      "evidence": [
        "same-run retry test returns the existing unfinished batch identifier",
        "new-batch test succeeds only after feedback next_action is continue_submission"
      ],
      "status": "external-unverified"
    },
    {
      "id": "requirement-dictionary-snapshot-binding",
      "requirement": "every executable requirement, immutable snapshot, and selection result stores the exact approved dictionary_version and dictionary_hash",
      "owner": "requirement-and-field-selection-services",
      "evidence": [
        "non-null fields and foreign-reference checks cover dictionary_version plus dictionary_hash",
        "mismatched version/hash fixtures fail closed without creating a snapshot or selection"
      ],
      "status": "external-unverified"
    },
    {
      "id": "single-platform-execution-unit",
      "requirement": "each customer_demands row has exactly one platform and is physically unique by (requirement_head_id, platform, requirement_version)",
      "owner": "requirement-service",
      "evidence": [
        "physical unique constraint uq-customer-demands-head-platform-version exists",
        "multi-platform intake creates sibling child requirements under one requirement head"
      ],
      "status": "external-unverified"
    },
    {
      "id": "immutable-snapshot-and-audit-lineage",
      "requirement": "requirement snapshots, risk audits, feedback audits, and offer promotion events are append-only and cannot be rewritten in place",
      "owner": "production-database-and-owning-services",
      "evidence": [
        "database permissions or triggers reject update/delete for immutable records",
        "correction scenarios append a new version or audit event and preserve prior hashes"
      ],
      "status": "external-unverified"
    },
    {
      "id": "late-data-does-not-mutate-frozen-results",
