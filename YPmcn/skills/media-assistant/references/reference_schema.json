{"schemaVersion":1,"table":"ypmcn.customer_demands","verifiedAt":"2026-07-18","columns":[{"Field":"id","Type":"char(32)","InputShape":"string (Provider-managed)","Example":"0123456789abcdef0123456789abcdef","FilterMode":"-","Null":"NO","Key":"PRI","Default":"","Extra":"","Comment":"主键ID；数据库必填且由Provider生成；Agent不得传入或复用"},{"Field":"demandId","Type":"varchar(255)","InputShape":"string","Example":"DEMAND-20260718-001","FilterMode":"-","Null":"YES","Key":"MUL","Default":"","Extra":"","Comment":"原需求ID；仅补充同一需求的新版本时沿用Provider返回值"},{"Field":"demandVersion","Type":"int","InputShape":"integer (Provider-managed)","Example":"1","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"需求版本；由Provider原子分配；Agent不得自行递增"},{"Field":"status","Type":"enum('draft','ready','closed','archived')","InputShape":"enum-string","Example":"ready","FilterMode":"-","Null":"NO","Key":"MUL","Default":"","Extra":"","Comment":"需求状态；通过门禁后固定传ready"},{"Field":"brandName","Type":"varchar(255)","InputShape":"string","Example":"示例品牌","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"客户品牌名"},{"Field":"projectName","Type":"varchar(255)","InputShape":"string","Example":"夏季新品推广项目","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"项目名称"},{"Field":"product","Type":"varchar(255)","InputShape":"string","Example":"保湿精华","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"产品"},{"Field":"platform","Type":"varchar(32)","InputShape":"string","Example":"xiaohongshu","FilterMode":"xiaohongshu/douyin","Null":"NO","Key":"","Default":"","Extra":"","Comment":"平台；Brief业务必填；仅允许xiaohongshu或douyin"},{"Field":"rebate","Type":"varchar(255)","InputShape":"range-string [min,max]","Example":"[0.05,0.1]","FilterMode":"[min,max]","Null":"NO","Key":"","Default":"","Extra":"","Comment":"返点范围；固定写成[min,max]字符串；百分比先除以100；业务未提供时不得猜测"},{"Field":"quantityTotal","Type":"int","InputShape":"integer","Example":"10","FilterMode":"-","Null":"NO","Key":"","Default":"","Extra":"","Comment":"客户需要的达人数量；Brief业务必填且必须为正整数"},{"Field":"projectStartStart","Type":"datetime","InputShape":"datetime-string YYYY-MM-DD HH:mm:ss","Example":"2026-08-01 00:00:00","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"项目起始时间"},{"Field":"projectStartEnd","Type":"datetime","InputShape":"datetime-string YYYY-MM-DD HH:mm:ss","Example":"2026-08-31 23:59:00","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"项目结束时间"},{"Field":"submissionDeadlineAt","Type":"datetime","InputShape":"datetime-string YYYY-MM-DD HH:mm:ss","Example":"2026-07-25 18:00:00","FilterMode":"-","Null":"NO","Key":"","Default":"","Extra":"","Comment":"提交时间；Brief业务必填；格式YYYY-MM-DD HH:mm:ss"},{"Field":"rawMessagesJson","Type":"json","InputShape":"json-object","Example":"{\"schemaVersion\":\"ypmcn-brief-v1\",\"originalBrief\":\"招募10位小红书美妆达人推广保湿精华\",\"atoms\":[{\"sourceText\":\"招募10位小红书美妆达人\",\"disposition\":\"mapped\",\"targetField\":\"quantityTotal\",\"confidence\":1,\"inferred\":false}],\"coverageCheck\":{\"atomCount\":1,\"mappedCount\":1,\"preservedCount\":0,\"unresolvedCount\":0}}","FilterMode":"-","Null":"NO","Key":"","Default":"","Extra":"","Comment":"原始需求审计JSON；Agent必须由完整Brief生成ypmcn-brief-v1对象"},{"Field":"createdAt","Type":"datetime","InputShape":"datetime-string YYYY-MM-DD HH:mm:ss (Provider-managed)","Example":"2026-07-18 10:00:00","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"创建时间；由Provider写入"},{"Field":"updatedAt","Type":"datetime","InputShape":"datetime-string YYYY-MM-DD HH:mm:ss (Provider-managed)","Example":"2026-07-18 12:00:00","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"更新时间；由Provider写入"},{"Field":"contentTag","Type":"text","InputShape":"string","Example":"美妆,护肤","FilterMode":"向量查询","Null":"YES","Key":"","Default":"","Extra":"","Comment":"内容标签；多个值按客户原文用逗号分隔"},{"Field":"description","Type":"text","InputShape":"string","Example":"专注美妆护肤产品测评与成分科普","FilterMode":"向量查询","Null":"YES","Key":"","Default":"","Extra":"","Comment":"内容要求或达人介绍约束；不替代rawMessagesJson"},{"Field":"contentFeatureLabel","Type":"json","InputShape":"json-array","Example":"[\"成分讲解\",\"真人出镜\"]","FilterMode":"向量查询","Null":"YES","Key":"","Default":"","Extra":"","Comment":"内容特征标签JSON"},{"Field":"contentThemeLabel","Type":"json","InputShape":"json-array","Example":"[\"护肤测评\",\"好物推荐\"]","FilterMode":"向量查询","Null":"YES","Key":"","Default":"","Extra":"","Comment":"抖音内容主题标签JSON"},{"Field":"kolPersonaLabel","Type":"json","InputShape":"json-array","Example":"[\"专业测评\",\"精致生活\"]","FilterMode":"向量查询","Null":"YES","Key":"","Default":"","Extra":"","Comment":"达人人物画像标签JSON"},{"Field":"talentTypeLabel","Type":"json","InputShape":"json-array","Example":"[\"美妆达人\",\"种草达人\"]","FilterMode":"向量查询","Null":"YES","Key":"","Default":"","Extra":"","Comment":"达人类型标签JSON"},{"Field":"pgyBloggerTypeLabel","Type":"json","InputShape":"json-array","Example":"[\"美妆\",\"护肤\"]","FilterMode":"向量查询","Null":"YES","Key":"","Default":"","Extra":"","Comment":"蒲公英达人类型标签JSON"},{"Field":"xtTalentTypeLabel","Type":"json","InputShape":"json-array","Example":"[\"美妆\",\"生活方式\"]","FilterMode":"向量查询","Null":"YES","Key":"","Default":"","Extra":"","Comment":"星图达人类型标签JSON"},{"Field":"kwGender","Type":"varchar(16)","InputShape":"string","Example":"女","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"达人性别"},{"Field":"kwIpDependency","Type":"varchar(128)","InputShape":"string","Example":"上海","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"IP属地"},{"Field":"kwUserUrl","Type":"varchar(1024)","InputShape":"string","Example":"https://www.xiaohongshu.com/user/profile/example","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"参考达人主页URL"},{"Field":"organization","Type":"varchar(255)","InputShape":"string","Example":"示例MCN机构","FilterMode":"-","Null":"YES","Key":"","Default":"","Extra":"","Comment":"指定所属机构或MCN"},{"Field":"hasOrganization","Type":"tinyint(1)","InputShape":