{
  "name": "ypmcn-media-assistant",
  "version": "2.1.5",
  "description": "YPmcn 媒介助手 OpenClaw 插件：流程编排、MCP 调用、人工 gate 与达人提报管理",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    ".claude-plugin/",
    "dist/",
    "skills/",
    "scripts/check_distribution_readiness.py",
    "scripts/check_flow_order.py",
    "scripts/check_requirement_params.py",
    "scripts/send_wecom.py",
    "vector-mcp/dist/",
    "mcp.json",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "build:vector-mcp": "cd ../vector-mcp && npx tsc && mkdir -p ../YPmcn/vector-mcp && cp -r dist ../YPmcn/vector-mcp/",
    "test": "npm run build && node --test tests/*.test.mjs",
    "pack:yp": "npm run build && npm run build:vector-mcp && npm pack --pack-destination ..",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    }
  },
  "devDependencies": {
    "openclaw": "*",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "media",
    "mcn",
    "creator"
  ],
  "license": "MIT",
  "openclaw.hooks": "./dist/index.js",
  "openclaw.extensions": [
    "./dist/index.js"
  ]
}
